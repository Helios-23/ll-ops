#!/bin/bash
set -euo pipefail

DRIVER_PKG="nvidia-utils-{{ nvidia_driver_version }}"
IGNORE_REGEX='{{ nvidia_reboot_guard_ignore_cmd_regex }}'
MARKER_REASON='{{ nvidia_reboot_guard_marker_reason }}'
WATCH_USERS=(
{% for user in nvidia_reboot_guard_watch_users %}
  "{{ user }}"
{% endfor %}
)

loaded_version="$(
  sed -n 's/^NVRM version: NVIDIA UNIX .* Kernel Module  \([0-9.]\+\).*/\1/p' \
    /proc/driver/nvidia/version 2>/dev/null | head -n1
)"

userspace_version="$(
  dpkg-query -W -f='${Version}\n' "${DRIVER_PKG}" 2>/dev/null | head -n1
)"
userspace_version="${userspace_version%%-*}"

if [[ -z "${loaded_version}" || -z "${userspace_version}" ]]; then
  exit 0
fi

if [[ "${loaded_version}" == "${userspace_version}" ]]; then
  exit 0
fi

for user in "${WATCH_USERS[@]}"; do
  [[ -z "${user}" ]] && continue

  while IFS= read -r cmd; do
    [[ -z "${cmd}" ]] && continue

    if [[ ! "${cmd}" =~ ${IGNORE_REGEX} ]]; then
      logger -t nvidia-reboot-guard \
        "Detected NVIDIA userspace/kernel mismatch (${loaded_version} != ${userspace_version}) but user '${user}' still has active process: ${cmd}"
      exit 0
    fi
  done < <(ps -u "${user}" -o cmd= 2>/dev/null || true)
done

touch /run/reboot-required
touch /run/reboot-required.pkgs
grep -qxF "${MARKER_REASON}" /run/reboot-required.pkgs || echo "${MARKER_REASON}" >> /run/reboot-required.pkgs

logger -t nvidia-reboot-guard \
  "Flagged reboot required due to NVIDIA userspace/kernel mismatch (${loaded_version} != ${userspace_version})"
