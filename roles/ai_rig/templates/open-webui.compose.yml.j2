services:
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: open-webui
    restart: always
    networks:
      - ai_network
    ports:
      - "127.0.0.1:{{ agent_ui_port }}:8080"
    environment:
      OLLAMA_BASE_URL: "http://ollama:11434"
      ENABLE_API_KEYS: "true"
      USER_PERMISSIONS_FEATURES_API_KEYS: "true"
      ENABLE_PERSISTENT_CONFIG: "false"
      WEBUI_SECRET_KEY: "{{ webui_secret }}"
      ENABLE_MODEL_SELECT: "true"
      SHOW_ALL_MODELS: "{{ open_webui_show_all_models | string }}"
      MODEL_SELECTION_MODE: "{{ open_webui_model_selection }}"
      DEFAULT_MODELS: "deepseek-coder-v2:16b"
      ENABLE_SIGNUP: "false"
      DEFAULT_USER_ROLE: "user"
      WEBUI_ADMIN_EMAIL: "{{ webui_admin_user }}"
      WEBUI_ADMIN_PASSWORD: "{{ webui_admin_pass }}"
      WEBUI_ADMIN_NAME: "Admin"
      ENABLE_OLLAMA_API: "true"
      BYPASS_MODEL_ACCESS_CONTROL: "true"
      GOOGLE_DRIVE_FOLDER_ID: "{{ google_drive_folder_id }}"
      GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY: "/app/backend/data/service-key.json"
    volumes:
      - {{ open_webui_data_path }}:/app/backend/data

networks:
  ai_network:
    external: true
