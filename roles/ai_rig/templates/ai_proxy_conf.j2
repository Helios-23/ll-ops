map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 443 ssl http2;
    server_name {{ ai_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ ai_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ ai_domain }}/privkey.pem;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_buffering {{ nginx_proxy_buffering }};
    proxy_cache off;
    chunked_transfer_encoding on;
    tcp_nopush on;
    tcp_nodelay on;

    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    proxy_read_timeout {{ nginx_read_timeout }};
    proxy_connect_timeout {{ nginx_read_timeout }};
    proxy_send_timeout {{ nginx_read_timeout }};
    client_max_body_size 128M;

    location / {
        proxy_pass http://127.0.0.1:{{ agent_ui_port }};
    }

    location /ollama/ {
        rewrite ^/ollama/(.*) /$1 break;
        proxy_pass http://127.0.0.1:{{ ollama_port }};
    }
}

server {
    listen 80;
    server_name {{ ai_domain }};
    return 301 https://$host$request_uri;
}
