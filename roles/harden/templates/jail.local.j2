[DEFAULT]
# Ban for 12 hours
bantime = 43200
# Find time window for counting attempts
findtime = 600
# Number of attempts before ban
maxretry = 3
# Use iptables for banning
banaction = iptables-multiport
# Email action (optional)
destemail = {{ fail2ban_admin_email | default('root@localhost') }}
sender = fail2ban@{{ inventory_hostname }}
# Whitelisted IPs - bypass fail2ban
ignoreip = 127.0.0.1/8 ::1 {{ whitelisted_ips | join(' ') }}

[sshd]
enabled = true
port = {{ ([sshd_port] + (sshd_additional_protected_ports | default([]))) | unique | join(',') }}
filter = sshd-custom
logpath = /var/log/auth.log
maxretry = 3
bantime = 43200

[sshd-ddos]
enabled = true
port = {{ ([sshd_port] + (sshd_additional_protected_ports | default([]))) | unique | join(',') }}
filter = sshd-ddos
logpath = /var/log/auth.log
maxretry = 2
bantime = 86400

# Custom aggressive jail for rapid attempts
[sshd-aggressive]
enabled = true
port = {{ ([sshd_port] + (sshd_additional_protected_ports | default([]))) | unique | join(',') }}
filter = sshd-custom
logpath = /var/log/auth.log
maxretry = 2
findtime = 300
bantime = 86400

{% if fail2ban_feature_reverse_proxy_enabled | bool %}
[nginx-auth-proxy]
enabled = true
port = {{ reverse_proxy_fail2ban_ports }}
filter = nginx-auth-proxy
logpath = {{ reverse_proxy_fail2ban_logpath }}
maxretry = {{ reverse_proxy_fail2ban_maxretry }}
findtime = {{ reverse_proxy_fail2ban_findtime }}
bantime = {{ reverse_proxy_fail2ban_bantime }}
{% endif %}

{% if fail2ban_feature_sshd_invalid_user_enabled | bool %}
[sshd-invalid-user]
enabled = true
port = {{ ([sshd_port] + (sshd_additional_protected_ports | default([]))) | unique | join(',') }}
filter = sshd-invalid-user
logpath = {{ fail2ban_sshd_invalid_user_logpath }}
maxretry = {{ fail2ban_sshd_invalid_user_maxretry }}
findtime = {{ fail2ban_sshd_invalid_user_findtime }}
bantime = {{ fail2ban_sshd_invalid_user_bantime }}
{% endif %}

{% if fail2ban_feature_forgejo_enabled | bool %}
[forgejo]
enabled = true
filter = forgejo
logpath = {{ forgejo_fail2ban_logpath }}
maxretry = {{ forgejo_fail2ban_maxretry }}
findtime = {{ forgejo_fail2ban_findtime }}
bantime = {{ forgejo_fail2ban_bantime }}
action = iptables-allports[chain="FORWARD"]
{% endif %}
