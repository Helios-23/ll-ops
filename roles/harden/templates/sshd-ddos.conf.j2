# Fail2Ban filter for SSH DDoS attacks
# Detects rapid connection attempts from a single source

[Definition]

# Matches "Did not receive identification string from <IP>"
# Indicates rapid connection attempts without completing SSH handshake
failregex = ^%(__prefix_line)sDid not receive identification string from <HOST>$ 
            ^%(__prefix_line)sConnection closed by <HOST> \[preauth\]$
            ^%(__prefix_line)sConnection reset by <HOST> \[preauth\]$
            ^%(__prefix_line)sBad protocol version identification .* from <HOST>$
            ^%(__prefix_line)sReceived disconnect from <HOST>: 11: .* \[preauth\]$

# Common prefix line for SSH logs
__prefix_line = \s*(?:\S+ )?(?:kernel: \[\d+\.\d+\] )?(?:@vserver_\S+ )?(?:\[sshd\])?(?:\[pid \d+\])?(?:\[priv\])? (?:\S+ )?ssh(d)?(\[\d+\])?:?

ignoreregex =

[Init]
journalmatch = _SYSTEMD_UNIT=ssh.service
