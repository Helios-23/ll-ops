upstream lantern_app {
{% if lantern_use_socket %}
    server unix:{{ lantern_socket_path }};
{% else %}
    server {{ lantern_service_host }}:{{ lantern_service_port }};
{% endif %}
}

server {
    listen 80;
    server_name {{ lantern_domain }};

    location ~ ^/\.well-known/acme-challenge/(.+)$ {
        alias /var/www/certbot/.well-known/acme-challenge/$1;
        default_type text/plain;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name {{ lantern_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ lantern_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ lantern_domain }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    access_log {{ lantern_access_log }};
    error_log {{ lantern_error_log }};

    client_max_body_size 128M;

    location = / {
        return 301 /atlas;
    }

    location / {
        proxy_pass http://lantern_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_read_timeout 600s;
        proxy_connect_timeout 600s;
        proxy_send_timeout 600s;
    }
}
