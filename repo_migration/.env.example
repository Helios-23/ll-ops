# Environment variables for GitHub to Forgejo migration
# Source this file before running migration scripts:
# source /Users/H23/logicallight/Epytype/ops/repo_migration/.env

# === GitHub Configuration ===
# IMPORTANT: Use CLASSIC token (not fine-grained) for shared repos
# Go to: https://github.com/settings/tokens/classic
# Token needs: repo (full), read:org
export GITHUB_TOKEN="ghp_your_classic_github_token_here"
export GITHUB_ORG="shared-org-name"            # Organization that owns the repos
# export GITHUB_USER="your-username"            # Uncomment if repos are shared to your user

# === Why Classic Token? ===
# Fine-grained tokens require selecting specific repos, which doesn't work
# for repos shared with you. Classic tokens with 'repo' scope can access
# all repositories you have permission to read.

# === Forgejo Configuration ===

# === Forgejo Configuration ===
export FORGEJO_ADMIN_TOKEN="your_forgejo_admin_token_here"
export FORGEJO_URL="https://repo.epytype.org"

# === Migration Target ===
export TARGET_ORG="your_forgejo_org"           # Leave empty to put repos under admin user
export CLONE_DIR="/tmp/repo_migration"          # Temporary clone location

# === Optional Settings ===
export OUTPUT_FILE="github_repos.txt"           # List of repos to migrate
export BACKUP_REMOTE="github-backup"            # Name for backup remote when updating locals

# === Instructions ===
# 1. Get GitHub token: https://github.com/settings/tokens
#    - Scopes needed: repo (all), read:org
#
# 2. Get Forgejo token: https://repo.epytype.org/user/settings/applications
#    - Scopes needed: repo, admin:org
#
# 3. Uncomment and fill in the values above
#
# 4. Run migration:
#    cd /Users/H23/logicallight/Epytype/ops/repo_migration/scripts
#    source ../.env
#    ./list_github_repos.sh
#    ./batch_migrate.sh github_repos.txt
